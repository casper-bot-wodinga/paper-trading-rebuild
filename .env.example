# Docker Compose environment variables for paper-trading-rebuild
# Copy to .env on docker.klo and fill in your keys.
# NEVER commit .env to git — it contains secrets.

# Alpaca per-trader API keys
ALPACA_KAIROS_KEY=your_alpaca_kairos_key
ALPACA_KAIROS_SECRET=your_alpaca_kairos_secret
ALPACA_ALDRIDGE_KEY=your_alpaca_aldridge_key
ALPACA_ALDRIDGE_SECRET=your_alpaca_aldridge_secret
ALPACA_STONKS_KEY=your_alpaca_stonks_key
ALPACA_STONKS_SECRET=your_alpaca_stonks_secret

# OpenRouter (LLM inference)
KAIROS_API_KEY=sk-or-...
KAIROS_SECRET_KEY=... (same as above)
ALDRIDGE_API_KEY=sk-or-...
ALDRIDGE_SECRET_KEY=... (same as above)
STONKS_API_KEY=sk-or-...
STONKS_SECRET_KEY=... (same as above)
OPENROUTER_API_KEY=sk-or-...

# Data providers
FINNHUB_API_KEY=your_finnhub_key
FRED_API_KEY=your_fred_key
ALPHA_VANTAGE_KEY=your_alphavantage_key
