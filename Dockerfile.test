# ─────────────────────────────────────────────────────────────────────────────
# Test Runner Dockerfile — Full CI stack for containerized testing
#
# Extends the base Dockerfile with test-specific dependencies:
#   - pytest + plugins (timeout, junitxml, cov)
#   - Playwright (for E2E browser tests)
#   - All production deps from requirements.txt
#
# Build & run:
#   docker build -f Dockerfile.test -t paper-trading-test .
#   docker compose -f docker-compose.test.yml up --build --abort-on-container-exit
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.12-slim

# ── System deps ─────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    # Playwright browser deps
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libdbus-1-3 libxkbcommon0 libxcomposite1 \
    libxdamage1 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 \
    libcairo2 libasound2 libatspi2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js for Playwright ──────────────────────────────────────────────────
# Install Node.js via nodesource (or use apt)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Python deps ─────────────────────────────────────────────────────────────
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt \
    && pip install --no-cache-dir \
        pytest>=8.0 \
        pytest-timeout>=2.0 \
        pytest-xdist>=3.0 \
        pytest-cov>=5.0

# ── Playwright ──────────────────────────────────────────────────────────────
RUN npx playwright install chromium --with-deps 2>/dev/null || \
    echo "Playwright install skipped (will run without browser tests)"

ENV PYTHONUNBUFFERED=1
ENV PAPER=true
ENV CI=true

COPY . /app/
WORKDIR /app
